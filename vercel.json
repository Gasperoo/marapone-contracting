      "destination": "/work.html"
    },
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/security",
      "destination": "/security.html"
    },
    {
      "source": "/badge",
      "destination": "/badge.html"
    },
    {
      "source": "/discovery",
      "destination": "/discovery.html"
    },
    {
