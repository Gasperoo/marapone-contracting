{
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/how-it-works",
      "destination": "/how-it-works.html"
    },
    {
      "source": "/api/account/(.*)",
      "destination": "/api/express"
    },
    {
      "source": "/api/stripe/(.*)",
      "destination": "/api/express"
    },
    {
      "source": "/api/health",
      "destination": "/api/express"
    }
  ]
}
